{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Seeker",
	"version": "0.1.0",
	"identifier": "com.yanis.seeker",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"title": "",
				"width": 1000,
				"height": 700,
				"transparent": true,
				"titleBarStyle": "Overlay"
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": ["$APPLOCALDATA/resources/**"]
			},
			"capabilities": [
				{
					"identifier": "window-controls",
					"windows": ["*"],
					"permissions": [
						"core:window:allow-start-dragging",
						"core:window:allow-toggle-maximize",
						"core:window:allow-create",
						"core:window:allow-close"
					]
				},
				{
					"identifier": "default",
					"windows": ["*"],
					"permissions": ["core:default", "core:path:default"]
				}
			]
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
